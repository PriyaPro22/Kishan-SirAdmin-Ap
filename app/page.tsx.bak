"use client";
import { useState, useEffect, useRef, useMemo } from "react";
import axios from "axios";
import {
  Search,
  MapPin,
  Bell,
  Bike,
  Wrench,
  Fan,
  Tv,
  Refrigerator,
  Smartphone,
  Laptop,
  ChevronRight,
  Loader2,
  Navigation,
  History,
  Moon,
  Sun,
  Home,
  Cpu,
  Phone,
  Printer,
  Microwave,
  Tablet,
  Monitor,
  X,
  Star,
  Clock,
  Shield,
  Check,
  Users,
  Wind,
  Droplets,
  Thermometer,
  Grid3x3,
  ShoppingCart,
  User,
  Plus,
  Minus,
  ChevronLeft,
  Image,
  Briefcase,
  Mic,
  Gift,
  Heart,
  Wallet,
  Settings,
  Zap,
  Compass,
  Map,
  ClipboardList,
  Lamp,
} from "lucide-react";
import Link from "next/link";
import { useRouter } from "next/navigation";
import { useApp } from "./context/AppContext";
import { motion, AnimatePresence } from "framer-motion";
import ServiceUnavailableModal from "./components/ServiceUnavailableModal";
import { ultraAPI } from "./lib/ultraAPI";
import LocationHeader from "./components/LocationHeader"; // Import LocationHeader
import Lottie from 'lottie-react'; // Import Lottie
import userFallbackAnimation from './components/animations/user-fallback.json'; // Import Animation

import dynamic from 'next/dynamic';

// Dynamic imports for heavy UI components
const DepartmentSheet = dynamic(() => import('./components/DepartmentSheet'), { ssr: false });
const AuthModal = dynamic(() => import('./components/Auth/AuthModal'), { ssr: false });
const RiderModeDashboard = dynamic(() => import('./components/RiderModeDashboard'), { ssr: false });
const ProfileView = dynamic(() => import('./components/ProfileView'), { ssr: false });
const LocationButton = dynamic(() => import('./components/LocationButton'), { ssr: false });
const NotificationSheet = dynamic(() => import('./components/NotificationSheet'), { ssr: false });
const EditProfileSheet = dynamic(() => import('./components/EditProfileSheet'), { ssr: false });

export default function HomePage() {
  const router = useRouter();
  const { darkMode, toggleDarkMode, showBottomNav, setShowBottomNav, openModal } = useApp();

  // ---------- State ----------
  const [activeTab, setActiveTab] = useState("Service");
  const [showDepartmentSheet, setShowDepartmentSheet] = useState(false);
  const [showCategoryPopup, setShowCategoryPopup] = useState(false);
  const [showChildCategoryPopup, setShowChildCategoryPopup] = useState(false);
  const [showNotAvailable, setShowNotAvailable] = useState(false);
  const [activeService, setActiveService] = useState<any>(null);
  const [activeSubCategory, setActiveSubCategory] = useState<any>(null);
  const [activeChildCategory, setActiveChildCategory] = useState<any>(null);
  const [subCategories, setSubCategories] = useState<any[]>([]);
  const [childCategories, setChildCategories] = useState<any[]>([]);
  const [deepCategories, setDeepCategories] = useState<any[]>([]);
  const [subDeepCategories, setSubDeepCategories] = useState<any[]>([]);
  const [activeNavId, setActiveNavId] = useState('home');
  const [loadingSubCategories, setLoadingSubCategories] = useState(false);
  const [loadingChildCategories, setLoadingChildCategories] = useState(false);
  const [servicesFromApi, setServicesFromApi] = useState<any[]>([]);
  const [loadingServices, setLoadingServices] = useState(false);
  const [userBookings, setUserBookings] = useState<any[]>([]);
  const [loadingBookings, setLoadingBookings] = useState(false);
  const [selectedDepartment, setSelectedDepartment] = useState("all");
  const [location, setLocation] = useState("Loading...");
  const [currentLevel, setCurrentLevel] = useState<'main' | 'sub' | 'child' | 'deep' | 'subDeep'>('main');
  const [popupHistory, setPopupHistory] = useState<any[]>([]);
  const [childPopupHistory, setChildPopupHistory] = useState<any[]>([]);
  const [loadingLocation, setLoadingLocation] = useState(true);
  const [quantities, setQuantities] = useState<Record<number, number>>({});
  const [clickPosition, setClickPosition] = useState({ x: 0, y: 0 });
  const [isSearchExpanded, setIsSearchExpanded] = useState(false);
  const [userData, setUserData] = useState<any>(null);
  const lastScrollY = useRef(0);
  const navigationCache = useRef<Record<string, { sub: any[], child: any[] }>>({});
  const prefetchQueue = useRef<string[]>([]);
  const isPrefetching = useRef(false);
  const [showPremiumUnavailable, setShowPremiumUnavailable] = useState(false);
  const [unavailableServiceName, setUnavailableServiceName] = useState("");
  const [showNotificationSheet, setShowNotificationSheet] = useState(false);
  const [notifications, setNotifications] = useState<any[]>([]);
  const [showEditProfileSheet, setShowEditProfileSheet] = useState(false);
  const [showRiderDashboard, setShowRiderDashboard] = useState(false);
  const [searchQuery, setSearchQuery] = useState("");

  const appSections = useMemo(() => [
    { id: 'home', name: 'Home', icon: <Home size={18} />, tab: 'home' },
    { id: 'bookings', name: 'Bookings', icon: <History size={18} />, tab: 'bookings', clickAction: () => { if (!userData) openModal('auth'); else setActiveTab('bookings'); } },
    { id: 'shopping', name: 'Shopping', icon: <Smartphone size={18} />, tab: 'home', clickTarget: 'Shopping' },
    { id: 'resell', name: 'Resell', icon: <Tv size={18} />, tab: 'home', clickAction: () => router.push('/test-notification') },
    { id: 'profile', name: 'Profile Account', icon: <User size={18} />, tab: 'home', clickAction: () => { if (!userData) openModal('auth'); else setShowEditProfileSheet(true); } },
    { id: 'wallet', name: 'Wallet & Payments', icon: <Wallet size={18} />, tab: 'home', clickAction: () => setShowEditProfileSheet(true) },
    { id: 'favorites', name: 'Favorites', icon: <Heart size={18} />, tab: 'home', clickAction: () => { setActiveTab('Service'); setSelectedDepartment('all'); } },
    { id: 'rewards', name: 'Rewards & Offers', icon: <Gift size={18} />, tab: 'home' },
    { id: 'settings', name: 'Settings', icon: <Settings size={18} />, tab: 'home', clickAction: () => setShowEditProfileSheet(true) },
    { id: 'dark_mode', name: 'Dark Mode Toggle', icon: <Moon size={18} />, tab: 'home', clickAction: () => toggleDarkMode() },
    { id: 'light_mode', name: 'Light Mode', icon: <Sun size={18} />, tab: 'home', clickAction: () => { if (darkMode) toggleDarkMode(); } },
    { id: 'rider_mode', name: 'Rider Mode (Work with us)', icon: <Bike size={18} />, tab: 'home', clickAction: () => { if (!userData) openModal('auth'); else setShowRiderDashboard(true); } },
    { id: 'direct_hire', name: 'Direct Hire Expert', icon: <Users size={18} />, tab: 'home' },
    { id: 'instant_service', name: 'Instant Service (Urgent)', icon: <Zap size={18} />, tab: 'home' },
    { id: 'location_settings', name: 'Change Location', icon: <MapPin size={18} />, tab: 'home' },
  ], [darkMode, toggleDarkMode]);

  const filteredResults = useMemo(() => {
    if (!searchQuery.trim()) return { services: [], bookings: [], sections: [] };
    const query = searchQuery.toLowerCase();

    // 1. Search Main, Sub, and Child Categories
    const matchedServices: any[] = [];

    // Search Main Categories
    servicesFromApi.forEach(main => {
      const mainName = main.name || main.serviceName || '';
      if (mainName.toLowerCase().includes(query)) {
        matchedServices.push({ ...main, type: 'Main Category' });
      }

      // Check Cache for Deep Search
      const cached = navigationCache.current[main._id || main.documentId];
      if (cached) {
        cached.sub?.forEach(sub => {
          if (sub.name?.toLowerCase().includes(query)) {
            matchedServices.push({ ...sub, parent: main, type: 'Sub Category' });
          }
        });
        cached.child?.forEach(child => {
          if (child.name?.toLowerCase().includes(query)) {
            matchedServices.push({ ...child, parent: main, type: 'Service' });
          }
        });
      }
    });

    return {
      services: matchedServices.slice(0, 8),
      bookings: userBookings.filter(b =>
        (b.serviceName || '').toLowerCase().includes(query) ||
        (b.documentId || '').toLowerCase().includes(query) ||
        (b.status || '').toLowerCase().includes(query)
      ).slice(0, 5),
      sections: appSections.filter(sec =>
        sec.name.toLowerCase().includes(query)
      )
    };
  }, [searchQuery, servicesFromApi, userBookings, appSections]);

  // ---------- Auto-Location Trigger ----------
  useEffect(() => {
    const detectLocation = async () => {
      if (typeof window !== 'undefined' && navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
          async (position) => {
            const { latitude, longitude } = position.coords;
            try {
              const apiKey = process.env.NEXT_PUBLIC_GOOGLE_MAPS_KEY;
              const res = await axios.get(`https://maps.googleapis.com/maps/api/geocode/json?latlng=${latitude},${longitude}&key=${apiKey}`);
              if (res.data.results && res.data.results[0]) {
                const addr = res.data.results[0].formatted_address;
                setLocation(addr);
                localStorage.setItem('userLocation', addr);
              } else {
                throw new Error("No results from Google");
              }
            } catch (e) {
              console.log("Geocoding failed", e);
              setLocation(`${latitude.toFixed(4)}, ${longitude.toFixed(4)}`);
            }
          },
          (err) => console.log("Location permission error:", err),
          { enableHighAccuracy: true, timeout: 5000 }
        );
      }
    };
    detectLocation();
  }, []);

  // ---------- Advanced Story Banner State ----------
  const banners = [
    {
      id: 1,
      type: 'image',
      url: 'https://images.unsplash.com/photo-1621905251189-08b45d6a269e?q=80&w=2069&auto=format&fit=crop',
      title: 'Winter Sale Live!',
      subtitle: 'Get up to 40% off on all AC services this month.',
      duration: 5000 // 5 seconds for images
    },
    {
      id: 2,
      type: 'video',
      url: 'https://assets.mixkit.co/videos/preview/mixkit-technician-checking-an-air-conditioner-unit-43340-large.mp4',
      title: 'Expert Installation',
      subtitle: 'Certified professionals at your doorstep within 60 mins.',
      duration: 0 // Will be determined by video length
    },
    {
      id: 3,
      type: 'image',
      url: 'https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?q=80&w=2070&auto=format&fit=crop',
      title: 'Smart Home Fix',
      subtitle: 'Complete home inspection starting at just ₹199 only.',
      duration: 5000
    }
  ];

  const [currentIndex, setCurrentIndex] = useState(0);
  const [progress, setProgress] = useState(0);
  const videoRef = useRef<HTMLVideoElement>(null);

  useEffect(() => {
    let interval: NodeJS.Timeout;
    const currentBanner = banners[currentIndex];

    if (currentBanner.type === 'image') {
      const startTime = Date.now();
      interval = setInterval(() => {
        const elapsed = Date.now() - startTime;
        const newProgress = (elapsed / currentBanner.duration) * 100;

        if (newProgress >= 100) {
          setProgress(0);
          setCurrentIndex((prev) => (prev + 1) % banners.length);
        } else {
          setProgress(newProgress);
        }
      }, 50);
    }

    return () => clearInterval(interval);
  }, [currentIndex]);

  const handleVideoTimeUpdate = () => {
    if (videoRef.current) {
      const p = (videoRef.current.currentTime / videoRef.current.duration) * 100;
      setProgress(p);
    }
  };

  const handleVideoEnd = () => {
    setProgress(0);
    setCurrentIndex((prev) => (prev + 1) % banners.length);
  };

  useEffect(() => {
    const handleScroll = () => {
      // If forced hide by other components, dont handle scroll
      // Actually scroll logic should still run but we'll deal with it in render
      const currentScrollY = window.scrollY;
      const scrollHeight = document.documentElement.scrollHeight;
      const clientHeight = document.documentElement.clientHeight;

      if (currentScrollY < 50) {
        setShowBottomNav(true);
      } else if (currentScrollY + clientHeight >= scrollHeight - 50) {
        setShowBottomNav(true);
      } else if (currentScrollY > lastScrollY.current + 10) {
        setShowBottomNav(false);
      } else if (currentScrollY < lastScrollY.current - 10) {
        setShowBottomNav(true);
      }
      lastScrollY.current = currentScrollY;
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    return () => window.removeEventListener("scroll", handleScroll);
  }, []);



  // ---------- Auto Login Popup & User Data Sync ----------
  useEffect(() => {
    const syncUserData = () => {
      const storedUserData = typeof window !== 'undefined' ? localStorage.getItem('userData') : null;
      if (storedUserData) {
        try {
          setUserData(JSON.parse(storedUserData));
        } catch (e) {
          console.error("Failed to parse user data", e);
        }
      } else {
        setUserData(null);
      }
    };

    syncUserData();

    // Data Sync Loop (Smooth Refresh)
    const syncInterval = setInterval(() => {
      console.log("🔄 [DataSync] Auto-refreshing services...");
      // Re-fetch services if on home tab
      if (activeNavId === 'home') {
        // We'll call a fetcher here if available, or just rely on existing ultraAPI cache logic
        // For now, we'll dispatch a refresh event
        window.dispatchEvent(new Event('refreshData'));
      }
    }, 30000); // 30s refresh

    // Listen for login/logout events
    window.addEventListener('userLoggedIn', syncUserData);
    window.addEventListener('userLoggedOut', syncUserData);
    window.addEventListener('refreshData', syncUserData); // Also sync user data on refresh

    return () => {
      clearInterval(syncInterval);
      window.removeEventListener('userLoggedIn', syncUserData);
      window.removeEventListener('userLoggedOut', syncUserData);
      window.removeEventListener('refreshData', syncUserData);
    };
  }, [activeNavId]);

  const departmentSectionRef = useRef<HTMLElement>(null);

  const tabs = ["Service", "Shopping", "Resell"];

  const allDepartments = useMemo(() => [
    {
      id: "all",
      name: "All",
      icon: <Grid3x3 className="w-8 h-8 text-white" />,
      image: null,
      bgColor: "bg-[#1F2937]",
      darkBgColor: "bg-[#1F2937]",
      isAll: true,
    },
    {
      id: "Home Appliances",
      name: "Home Appliances",
      icon: null,
      image: "/home-appliances.png",
      bgColor: "bg-gradient-to-br from-rose-100 to-rose-200",
      darkBgColor: "bg-gradient-to-br from-rose-900 to-rose-800",
    },
    {
      id: "Computer",
      name: "Computer",
      icon: null,
      image: "/computer.png",
      bgColor: "bg-gradient-to-br from-orange-100 to-orange-200",
      darkBgColor: "bg-gradient-to-br from-orange-900 to-orange-800",
    },
    {
      id: "Mobile",
      name: "Mobile",
      icon: null,
      image: "/mobile.png",
      bgColor: "bg-gradient-to-br from-emerald-100 to-emerald-200",
      darkBgColor: "bg-gradient-to-br from-emerald-900 to-emerald-800",
    },
  ], []);

  const departments = useMemo(() => {
    return allDepartments.filter(dept => {
      if (dept.id === "all") return true;
      // Show department only if there is at least one service with this parentId
      return servicesFromApi.some(service => service.parentId === dept.id);
    });
  }, [servicesFromApi, allDepartments]);

  const serviceIcons: Record<string, any> = {
    AC: <Wind size={24} className="text-blue-600 icon-spin-slow" />, // eslint-disable-line react/jsx-key
    "AC Repair": <Wind size={24} className="text-blue-600 icon-spin-slow" />, // eslint-disable-line react/jsx-key
    Fan: <Fan size={24} className="text-blue-600 icon-spin-slow" />, // eslint-disable-line react/jsx-key
    TV: <Tv size={24} className="text-blue-600" />, // eslint-disable-line react/jsx-key
    Fridge: <Refrigerator size={24} className="text-blue-600" />, // eslint-disable-line react/jsx-key
    Refrigerator: <Refrigerator size={24} className="text-blue-600" />, // eslint-disable-line react/jsx-key
    Mobile: <Smartphone size={24} className="text-purple-600" />, // eslint-disable-line react/jsx-key
    "Mobile Repair": <Smartphone size={24} className="text-purple-600 icon-pulse" />, // eslint-disable-line react/jsx-key
    Laptop: <Laptop size={24} className="text-green-600" />, // eslint-disable-line react/jsx-key
    "Laptop Repair": <Laptop size={24} className="text-green-600 icon-pulse" />, // eslint-disable-line react/jsx-key
    "Washing Machine": <Wrench size={24} className="text-blue-600" />, // eslint-disable-line react/jsx-key
    Microwave: <Microwave size={24} className="text-blue-600" />, // eslint-disable-line react/jsx-key
    "Water Purifier": <Droplets size={24} className="text-blue-600" />, // eslint-disable-line react/jsx-key
    Geyser: <Thermometer size={24} className="text-blue-600" />, // eslint-disable-line react/jsx-key
    "Kitchen Chimney": <Wind size={24} className="text-blue-600" />, // eslint-disable-line react/jsx-key
    "Desktop Repair": <Monitor size={24} className="text-green-600 icon-pulse" />, // eslint-disable-line react/jsx-key
    "Printer Repair": <Printer size={24} className="text-green-600 icon-pulse" />, // eslint-disable-line react/jsx-key
    "Data Recovery": <Cpu size={24} className="text-green-600" />, // eslint-disable-line react/jsx-key
    "Network Setup": <Cpu size={24} className="text-green-600" />, // eslint-disable-line react/jsx-key
    "Software Installation": <Cpu size={24} className="text-green-600" />, // eslint-disable-line react/jsx-key
    "Tablet Repair": <Tablet size={24} className="text-purple-600" />, // eslint-disable-line react/jsx-key
    "Screen Replacement": <Smartphone size={24} className="text-purple-600" />, // eslint-disable-line react/jsx-key
    "Battery Replacement": <Smartphone size={24} className="text-purple-600" />, // eslint-disable-line react/jsx-key
    "Software Update": <Smartphone size={24} className="text-purple-600" />, // eslint-disable-line react/jsx-key
    "Water Damage Repair": <Smartphone size={24} className="text-purple-600" />, // eslint-disable-line react/jsx-key
  };

  const getServiceStyle = (service: any) => {
    let bgColor = "bg-blue-50";
    let darkBgColor = "bg-blue-900/20";
    let iconColor = "text-blue-600";
    if (service.parentId === "Computer") {
      bgColor = "bg-green-50";
      darkBgColor = "bg-green-900/20";
      iconColor = "text-green-600";
    } else if (service.parentId === "Mobile") {
      bgColor = "bg-purple-50";
      darkBgColor = "bg-purple-900/20";
      iconColor = "text-purple-600";
    }
    return { bgColor, darkBgColor, iconColor };
  };

  const checkMainCategoryVisibility = (service: any) => {
    if (service.isMainCategoryVisible === false || service.isMainCategoryVisible === 'false') return false;
    return true;
  };

  const checkSubChildVisibility = (item: any) => {
    // 1. Must have some kind of name
    const categoryName = item.name || item.title || item.firstTitle || item.serviceName || item.firstTitle || item.secondTitle;
    if (!categoryName || categoryName === "") {
      return false;
    }

    // 2. Helper for falsy values
    const isFalsy = (val: any) => val === false || val === 'false' || val === '0' || val === 0;

    // 3. Status Check
    if (item.status === "inactive") {
      return false;
    }

    // 4. Specific Visibility Flags (If defined, they take priority)
    // We only hide if they are explicitly FALSE/FALSY. If undefined, we show.
    if (item.isSubCategoryVisible !== undefined && isFalsy(item.isSubCategoryVisible)) {
      return false;
    }
    if (item.deepCategoryVisible !== undefined && isFalsy(item.deepCategoryVisible)) {
      return false;
    }
    if (item.visibility !== undefined && isFalsy(item.visibility)) {
      return false;
    }
    if (item.visible !== undefined && isFalsy(item.visible)) {
      return false;
    }

    // Default: SHOW everything else to give "Direct Data"
    return true;
  };

  const checkChildCategoryVisibility = (item: any) => {
    if (item.visibility === false || item.visible === false) return false;
    if (!item.name) return false;
    return true;
  };

  const storeServiceIds = (mainId: string, subId?: string, childId?: string, mainTitle?: string, subTitle?: string, childTitle?: string) => {
    localStorage.setItem("mainId", mainId);
    if (mainTitle) localStorage.setItem("mainCategoryTitle", mainTitle);

    if (subId) {
      localStorage.setItem("subId", subId);
      if (subTitle) localStorage.setItem("subCategoryTitle", subTitle);
    } else {
      localStorage.removeItem("subId");
      localStorage.removeItem("subCategoryTitle");
    }

    if (childId) {
      localStorage.setItem("childId", childId);
      if (childTitle) localStorage.setItem("childCategoryTitle", childTitle);
    } else {
      localStorage.removeItem("childId");
      localStorage.removeItem("childCategoryTitle");
    }
  };

  const handleServiceClick = async (service: any, event?: React.MouseEvent<HTMLButtonElement>) => {
    const serviceId = service._id || service.id || service.documentId;
    const serviceName = service.name || service.serviceName;

    // Check for Resell redirection
    if (serviceName && (serviceName.toLowerCase() === 'resell' || serviceName.toLowerCase().includes('resell'))) {
      router.push('/test-notification');
      return;
    }

    // Capture click position for animation origin
    if (event) {
      const rect = event.currentTarget.getBoundingClientRect();
      setClickPosition({
        x: rect.left + rect.width / 2,
        y: rect.top + rect.height / 2
      });
    }

    if (!checkMainCategoryVisibility(service)) {
      return;
    }

    // 1. First check if we already have data in the cache
    const cachedData = navigationCache.current[serviceId];
    if (cachedData && (cachedData.sub.length > 0 || cachedData.child.length > 0)) {
      setActiveService(service);
      setPopupHistory([service]);
      storeServiceIds(serviceId, undefined, undefined, serviceName);

      if (cachedData.sub.length > 0) {
        setSubCategories(cachedData.sub);
        setCurrentLevel("sub");
        setShowCategoryPopup(true);
        return;
      }

      if (cachedData.child.length > 0) {
        router.push("/services");
        return;
      }
    }

    // 2. Check if subcategories are already embedded in the service object
    const embeddedSub = service.subCategory || service.subCategories;
    if (embeddedSub && typeof embeddedSub === 'object') {
      let list = [];
      if (Array.isArray(embeddedSub)) {
        list = embeddedSub;
      } else {
        list = Object.entries(embeddedSub)
          .filter(([k]) => !['_id', 'documentId', 'mainCategory', '__v', 'createdAt', 'updatedAt', 'subCategory', 'subCategories'].includes(k))
          .map(([k, v]) => ({ _id: (v as any)._id || (v as any).documentId || k, ...(v as any) }));
      }

      const filtered = list.filter((i: any) => checkSubChildVisibility(i));
      if (filtered.length > 0) {
        setSubCategories(filtered);
        setActiveService(service);
        setPopupHistory([service]);
        setCurrentLevel("sub");
        setShowCategoryPopup(true);
        storeServiceIds(serviceId, undefined, undefined, serviceName);
        // Save to cache for next time
        navigationCache.current[serviceId] = { sub: filtered, child: [] };
        return;
      }
    }

    // 3. Fallback to API Fetch
    setActiveService(service);
    setCurrentLevel("sub");
    setPopupHistory([service]);
    storeServiceIds(serviceId, undefined, undefined, serviceName);

    setLoadingSubCategories(true);
    try {
      const subResponse = await fetchSubCategories(serviceId);
      const childResponse = await fetchChildCategories(serviceId);

      // Update cache
      navigationCache.current[serviceId] = { sub: subResponse, child: childResponse };

      if (subResponse.length > 0) {
        setSubCategories(subResponse);
        setShowCategoryPopup(true);
        return;
      }

      // If no subcategories, try redirecting to services page directly for "Direct data"
      localStorage.setItem('mainId', serviceId);
      localStorage.setItem('mainCategoryTitle', serviceName);
      localStorage.removeItem('subId');
      localStorage.removeItem('subCategoryTitle');
      localStorage.removeItem('childId');
      localStorage.removeItem('childCategoryTitle');
      router.push("/services");
    } catch (e) {
      console.error("❌ [handleServiceClick] API Error:", e);
      // Even on error, try to show the services page
      router.push("/services");
    } finally {
      setLoadingSubCategories(false);
    }
  };

  const prefetchData = async (service: any) => {
    if (navigationCache.current[service._id]) return;
    try {
      const [sub, child] = await Promise.all([
        fetchSubCategories(service._id),
        fetchChildCategories(service._id)
      ]);
      navigationCache.current[service._id] = { sub, child };

      // Prefetch images for subcategories
      sub.forEach((s: any) => {
        if (s.imageUri) {
          const img = new (window as any).Image();
          img.src = s.imageUri;
        }
      });
      // Prefetch images for child categories
      child.forEach((c: any) => {
        if (c.imageUri) {
          const img = new (window as any).Image();
          img.src = c.imageUri;
        }
      });
    } catch (e) {
      // console.warn("Prefetch failed for", service._id, e);
    }
  };

  useEffect(() => {
    if (servicesFromApi.length > 0) {
      const startPrefetching = async () => {
        for (const service of servicesFromApi) {
          await prefetchData(service);
        }
      };
      startPrefetching();
    }
  }, [servicesFromApi]);

  // ---------- Ultra Fast Fetchers ----------

  const fetchSubCategories = async (mainId: string) => {
    try {
      const data: any = await ultraAPI.get(`/product-listing/main/${mainId}/sub`);
      if (!data?.success) return [];

      let rawData = data.data || data.subCategory || data.subCategories || data;
      if (rawData.subCategory && typeof rawData.subCategory === 'object' && !Array.isArray(rawData.subCategory)) {
        rawData = rawData.subCategory;
      }

      let list = [];
      if (Array.isArray(rawData)) {
        list = rawData;
      } else if (typeof rawData === "object") {
        list = Object.entries(rawData)
          .filter(([k]) => !['_id', 'documentId', 'mainCategory', '__v', 'createdAt', 'updatedAt', 'childCategory', 'childCat', 'childCatMedia', 'childCatVideo', 'childCatVideos', 'childCatImages'].includes(k))
          .map(([k, v]) => ({ _id: (v as any)._id || (v as any).documentId || k, ...(v as any) }));
      }

      const filtered = list.filter((i: any) => checkSubChildVisibility(i));
      return filtered;
    } catch (error) {
      console.error("❌ [fetchSubCategories] Error:", error);
      return [];
    }
  };

  const fetchChildCategories = async (mainId: string, subId?: string) => {
    const url = subId
      ? `/product-listing/main/${mainId}/sub/${subId}/child`
      : `/product-listing/main/${mainId}/child`;

    try {
      const data: any = await ultraAPI.get(url);
      if (!data?.success) return [];

      let rawData = data.data || data.childCategory || data.children || data;
      let list = [];
      if (Array.isArray(rawData)) {
        list = rawData;
      } else if (typeof rawData === "object") {
        list = Object.entries(rawData)
          .filter(([k]) => !['_id', 'documentId', 'mainCategory', '__v', 'createdAt', 'updatedAt', 'childCategory', 'childCat', 'childCatMedia', 'childCatVideo', 'childCatVideos', 'childCatImages'].includes(k))
          .map(([k, v]) => ({ _id: (v as any)._id || (v as any).documentId || k, ...(v as any) }));
      }

      const filtered = list.filter((i: any) => checkSubChildVisibility(i));
      console.log(`✅ [fetchChildCategories] Returning ${filtered.length} items`);
      return filtered;
    } catch (error) {
      console.error("❌ [fetchChildCategories] Error:", error);
      return [];
    }
  };

  const fetchDeepCategories = async (mainId: string, childId: string, subId?: string) => {
    console.log(`🚀 [fetchDeepCategories] mainId: ${mainId}, subId: ${subId || 'none'}, childId: ${childId}`);

    // Attempt 1: Standard 'child' path
    const url1 = subId
      ? `/product-listing/main/${mainId}/sub/${subId}/child/${childId}/deep`
      : `/product-listing/main/${mainId}/child/${childId}/deep`;

    // Attempt 2: Fallback 'child-key' path
    const url2 = subId
      ? `/product-listing/main/${mainId}/sub/${subId}/child-key/${childId}/deep`
      : `/product-listing/main/${mainId}/child-key/${childId}/deep`;

    const tryFetch = async (url: string) => {
      try {
        console.log(`📡 [fetchDeepCategories] Trying: ${url}`);
        const data: any = await ultraAPI.get(url, { cache: false }); // Disable cache for debug
        if (data?.success) return data;
        return null;
      } catch (e) { return null; }
    };

    try {
      let data = await tryFetch(url1);
      if (!data) {
        console.log(`⚠️ [fetchDeepCategories] Path 1 failed, trying fallback: ${url2}`);
        data = await tryFetch(url2);
      }

      if (!data) {
        console.warn(`❌ [fetchDeepCategories] All paths failed for childId: ${childId}`);
        return [];
      }

      console.log(`📦 [fetchDeepCategories] SUCCESS:`, data);
      let rawData = data.data || data.deepCategory || data.deepCategories || data;
      let list = [];
      if (Array.isArray(rawData)) {
        list = rawData;
      } else if (typeof rawData === "object") {
        list = Object.entries(rawData)
          .filter(([k]) => !['_id', 'documentId', 'mainCategory', '__v', 'createdAt', 'updatedAt', 'childCategory', 'childCat', 'childCatMedia', 'childCatVideo', 'childCatVideos', 'childCatImages'].includes(k))
          .map(([k, v]) => ({ _id: (v as any)._id || (v as any).documentId || k, ...(v as any) }));
      }

      const filtered = list.filter((i: any) => checkSubChildVisibility(i));
      console.log(`✅ [fetchDeepCategories] Returning ${filtered.length} items`);
      return filtered;
    } catch (error) {
      console.error("❌ [fetchDeepCategories] Fatal Error:", error);
      return [];
    }
  };

  const fetchSubDeepCategories = async (mainId: string, childId: string, deepId: string, subId?: string) => {
    console.log(`🚀 [fetchSubDeepCategories] mainId: ${mainId}, subId: ${subId || 'none'}, childId: ${childId}, deepId: ${deepId}`);

    // Attempt 1: Standard 'child' path
    const url1 = subId
      ? `/product-listing/main/${mainId}/sub/${subId}/child/${childId}/deep/${deepId}/sub`
      : `/product-listing/main/${mainId}/child/${childId}/deep/${deepId}/sub`;

    // Attempt 2: Fallback 'child-key' path
    const url2 = subId
      ? `/product-listing/main/${mainId}/sub/${subId}/child-key/${childId}/deep/${deepId}/sub`
      : `/product-listing/main/${mainId}/child-key/${childId}/deep/${deepId}/sub`;

    const tryFetch = async (url: string) => {
      try {
        console.log(`📡 [fetchSubDeepCategories] Trying: ${url}`);
        const data: any = await ultraAPI.get(url, { cache: false });
        if (data?.success) return data;
        return null;
      } catch (e) { return null; }
    };

    try {
      let data = await tryFetch(url1);
      if (!data) {
        console.log(`⚠️ [fetchSubDeepCategories] Path 1 failed, trying fallback: ${url2}`);
        data = await tryFetch(url2);
      }

      if (!data) {
        console.warn(`❌ [fetchSubDeepCategories] All paths failed for deepId: ${deepId}`);
        return [];
      }

      console.log(`📦 [fetchSubDeepCategories] SUCCESS:`, data);
      let rawData = data.data || data.subDeepCategory || data.subDeepCategories || data;
      let list = [];
      if (Array.isArray(rawData)) {
        list = rawData;
      } else if (typeof rawData === "object") {
        list = Object.entries(rawData)
          .filter(([k]) => !['_id', 'documentId', 'mainCategory', '__v', 'createdAt', 'updatedAt', 'childCategory', 'childCat', 'childCatMedia', 'childCatVideo', 'childCatVideos', 'childCatImages'].includes(k))
          .map(([k, v]) => ({ _id: (v as any)._id || (v as any).documentId || k, ...(v as any) }));
      }

      const filtered = list.filter((i: any) => checkSubChildVisibility(i));
      console.log(`✅ [fetchSubDeepCategories] Returning ${filtered.length} items`);
      return filtered;
    } catch (error) {
      console.error("❌ [fetchSubDeepCategories] Fatal Error:", error);
      return [];
    }
  };

  const handleSubCategoryClick = async (item: any) => {
    if (!activeService?._id) return;

    const mainId = localStorage.getItem("mainId") || activeService._id;
    const itemId = item._id || item.id || item.documentId;
    const itemName = item.name || item.title || item.firstTitle;

    console.log(`➡️ [handleSubCategoryClick] Redirecting to services with Sub: ${itemName}`);

    try {
      // Clear previous levels to avoid confusion on services page
      localStorage.removeItem("childId");
      localStorage.removeItem("childCategoryTitle");
      localStorage.removeItem("childKey");

      // Store current selection
      localStorage.setItem("subId", itemId);
      localStorage.setItem("subCategoryTitle", itemName);

      storeServiceIds(mainId, itemId, undefined, activeService.name, itemName, undefined);

      setShowCategoryPopup(false);
      router.push("/services");
    } catch (err) {
      console.error("❌ Navigation error:", err);
      router.push("/services");
    }
  };

  const handlePopupBack = async () => {
    if (popupHistory.length <= 1) {
      setShowCategoryPopup(false);
      setSubCategories([]);
      setActiveService(null);
      setCurrentLevel("main");
      setPopupHistory([]);
      return;
    }

    const newHistory = [...popupHistory];
    newHistory.pop(); // Remove current
    const prevItem = newHistory[newHistory.length - 1];
    setPopupHistory(newHistory);

    // Re-fetch previous level
    const mainId = localStorage.getItem("mainId");

    if (currentLevel === 'child') {
      const subs = await fetchSubCategories(mainId!);
      setSubCategories(subs);
      setCurrentLevel('sub');
      localStorage.removeItem("subId");
    } else if (currentLevel === 'deep') {
      const subId = localStorage.getItem("subId");
      const children = await fetchChildCategories(mainId!, subId || undefined);
      setSubCategories(children);
      setCurrentLevel('child');
      localStorage.removeItem("childId");
    } else if (currentLevel === 'subDeep') {
      const subId = localStorage.getItem("subId");
      const childId = localStorage.getItem("childId");
      const deeps = await fetchDeepCategories(mainId!, childId!, subId || undefined);
      setSubCategories(deeps);
      setCurrentLevel('deep');
    }
  };







  const getCurrentLocation = async () => {
    setLoadingLocation(true);
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        async (position) => {
          try {
            const response = await fetch(
              `https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${position.coords.latitude}&longitude=${position.coords.longitude}&localityLanguage=en`
            );
            const data = await response.json();
            if (data.city && data.countryName) setLocation(`${data.city}, ${data.countryName}`);
            else setLocation("New York, USA");
          } catch {
            setLocation("New York, USA");
          }
          setLoadingLocation(false);
        },
        () => {
          fetch("https://ipapi.co/json/")
            .then((r) => r.json())
            .then((data) => {
              if (data.city && data.country_name) setLocation(`${data.city}, ${data.country_name}`);
              else setLocation("New York, USA");
              setLoadingLocation(false);
            })
            .catch(() => {
              setLocation("New York, USA");
              setLoadingLocation(false);
            });
        }
      );
    } else {
      fetch("https://ipapi.co/json/")
        .then((r) => r.json())
        .then((data) => {
          if (data.city && data.country_name) setLocation(`${data.city}, ${data.country_name}`);
          else setLocation("New York, USA");
          setLoadingLocation(false);
        })
        .catch(() => {
          setLocation("New York, USA");
          setLoadingLocation(false);
        });
    }
  };

  useEffect(() => {
    const fetchMainCategories = async () => {
      try {
        setLoadingServices(true);
        const data: any = await ultraAPI.get("/product-listing/main");
        if (data?.success) {
          const raw = data.data;
          const list = Array.isArray(raw)
            ? raw
            : typeof raw === "object"
              ? Object.entries(raw).map(([k, v]) => ({ _id: (v as any)._id || (v as any).documentId || k, ...(v as any) }))
              : [];
          const visible = list.filter((s: any) => checkMainCategoryVisibility(s));
          setServicesFromApi(
            visible.map((s: any) => ({ ...s, hasSubCategory: s.hasSubCategory || undefined }))
          );
        } else {
          setServicesFromApi([]);
        }
      } catch (e) {
        console.error("Fetch failed:", e);
        setServicesFromApi([]);
      } finally {
        setLoadingServices(false);
      }
    };
    getCurrentLocation();
    fetchMainCategories();
  }, []);

  // ---------- Fetch Bookings History ----------
  useEffect(() => {
    const fetchBookings = async () => {
      const userId = localStorage.getItem('userId');
      const authToken = localStorage.getItem('authToken');

      if (!userId || activeNavId !== 'history') return;

      console.log("🚀 [BOOKINGS] Syncing with official API structure...");
      console.log("👤 [BOOKINGS] UID:", userId);

      setLoadingBookings(true);
      try {
        const baseUrl = process.env.NEXT_PUBLIC_API_BASE_URL || '';
        const url = `${baseUrl}/api/service/${userId}`;
        const res = await axios.get(url, {
          headers: { 'Authorization': `Bearer ${authToken}` }
        });

        console.log("📦 [BOOKINGS] Official API Response:", res.data);

        // DOCUMENTATION STRUCTURE: { success: true, data: { history: { ... } } } OR { success: true, history: { ... } }
        // We check both res.data and res.data.data for the 'history' field
        const historyData = res.data?.data?.history || res.data?.history || res.data?.data;

        if (historyData && typeof historyData === 'object' && !Array.isArray(historyData)) {
          // If historyData itself is the map (keys are service IDs)
          const list = Object.entries(historyData)
            .filter(([id, details]) => details && typeof details === 'object')
            .map(([id, details]: [string, any]) => ({
              serviceId: id,
              ...details
            }));

          console.log("🏆 [BOOKINGS] Found", list.length, "bookings.");
          setUserBookings(list.reverse()); // Show newest first
        } else if (Array.isArray(historyData)) {
          setUserBookings([...historyData].reverse());
        } else {
          console.warn("❔ [BOOKINGS] History is empty or not found in User document.");
          setUserBookings([]);
        }
      } catch (err: any) {
        console.error("❌ [BOOKINGS] API Sync Failed:", err.message);
        setUserBookings([]);
      } finally {
        setLoadingBookings(false);
      }
    };

    fetchBookings();
  }, [activeNavId, userData?.mobile]); // Use stable primitive for dependency

  // ---------- Categories Cleanup ----------
  // Removed static fallback data to prioritize live API data.

  const [sheetDepartment, setSheetDepartment] = useState("all");

  const handleDepartmentClick = (deptId: string) => {
    if (deptId === "all") {
      // "All" button just sets the filter for main page
      setSelectedDepartment(deptId);
      // Scroll to department section smoothly
      if (departmentSectionRef.current) {
        departmentSectionRef.current.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    } else {
      // Other department buttons open the sheet with that category
      // Don't change main page filter, just open sheet
      setSheetDepartment(deptId);
      setShowDepartmentSheet(true);
    }
  };

  const getFilteredServices = () => {
    // Simple filter based on selected department (placeholder logic)
    if (selectedDepartment === "all") return servicesFromApi;
    return servicesFromApi.filter((s) => s.parentId === selectedDepartment);
  };

  return (
    <div className={`min-h-screen ${darkMode ? "bg-[#050B14]" : "bg-[#F3F4F8]"} font-sans pb-36 transition-colors duration-300 relative overflow-hidden select-none`}>
      {/* HEADER - Only show on Home Tab */}
      {activeNavId === 'home' && (
        <header
          className={`rounded-b-[2.5rem] shadow-[0_10px_40px_-10px_rgba(0,0,0,0.15)] pt-10 pb-8 px-4 transition-colors duration-300 relative z-[70] ${darkMode ? "bg-[#111623] border-b border-white/5" : "bg-white border-b border-gray-100"}`}
        >
          <div className="flex items-center justify-between mb-8 relative px-0.5">
            {/* USER INFO & SEARCH OVERLAY */}
            <div className="flex items-center flex-1 relative h-11">
              <AnimatePresence>
                {!isSearchExpanded ? (
                  <motion.div
                    key="user-info"
                    initial={{ width: "auto", opacity: 1 }}
                    exit={{ width: 0, opacity: 0 }}
                    className="flex items-center gap-2.5 min-w-0"
                  >
                    <div
                      className="relative shrink-0 cursor-pointer active:scale-95 transition-transform"
                      onClick={() => {
                        const authToken = localStorage.getItem('authToken');
                        if (userData && authToken) {
                          setShowEditProfileSheet(true);
                        } else {
                          openModal('auth');
                        }
                      }}
                    >
                      <div className="w-11 h-11 rounded-full overflow-hidden">
                        <img
                          src={userData?.photoUrl || "https://lh3.googleusercontent.com/aida-public/AB6AXuCLmWXlraVbthm0L63bpSRaJEydrEok7JE99ttRdVvx04q0hzVBUPyTlfnqEZMBTzgdro42ssZFDeGpmjYTZat_5_-Ej7xnxEjfEwYlSWBkftespCDEPrUdMscaBgmCNF1t88-fx2pvtj6HZh7bGv0b_hZ_qjKveKkHluqGyxomHTv1SMxRxa3JNG-ixegBx8KXmvhlX-SKEvvQavucOt1ghTKyC5OrczCZO7yM7EMKNzQsweAiePwO6hXGnzl-rSQycpwIcvSxmQIm"}
                          alt="User"
                          className="w-full h-full object-cover"
                        />
                      </div>
                      <div
                        className="absolute bottom-0.5 right-0.5 w-2.5 h-2.5 bg-green-500 rounded-full shadow-sm"
                      />
                    </div>
                    <div className="overflow-hidden text-left flex flex-col justify-center">
                      <h1
                        className={`text-sm font-bold leading-tight cursor-pointer active:opacity-70 transition-opacity ${darkMode ? "text-white" : "text-[#111827]"}`}
                        onClick={() => {
                          const authToken = localStorage.getItem('authToken');
                          if (userData && authToken) {
                            setShowEditProfileSheet(true);
                          } else {
                            openModal('auth');
                          }
                        }}
                      >
                        Hi, {userData?.name?.split(' ')[0] || 'User'}
                      </h1>
                      <div className="mt-0.5">
                        <LocationButton
                          darkMode={darkMode}
                          onLocationChange={(newLocation) => {
                            // Update user data location
                            const updatedUserData = { ...userData, location: newLocation };
                            setUserData(updatedUserData);
                            localStorage.setItem('userData', JSON.stringify(updatedUserData));
                          }}
                        />
                      </div>
                    </div>
                  </motion.div>
                ) : (
                  <motion.div
                    key="search-bar"
                    initial={{ width: "100%", opacity: 0 }}
                    animate={{ opacity: 1 }}
                    exit={{ opacity: 0 }}
                    transition={{
                      duration: 0.6,
                      ease: [0.4, 0, 0.2, 1],
                    }}
                    className={`absolute inset-0 flex items-center pr-2 rounded-full ${darkMode ? "bg-white/10 backdrop-blur-xl border border-white/10" : "bg-black/5 backdrop-blur-xl border border-black/5"}`}
                  >
                    <div className="flex items-center w-full px-3">
                      <Search size={18} className={`shrink-0 ${darkMode ? "text-white" : "text-black"}`} />
                      <input
                        autoFocus
                        value={searchQuery}
                        onChange={(e) => setSearchQuery(e.target.value)}
                        className={`bg-transparent border-none outline-none focus:outline-none focus:ring-0 p-0 ml-3 text-sm w-full placeholder-gray-400 ${darkMode ? "text-gray-200" : "text-gray-700"}`}
                        placeholder="Search services, bookings..."
                        type="text"
                      />
                      {searchQuery && (
                        <button
                          onClick={() => setSearchQuery("")}
                          className={`p-1 mr-1 rounded-full hover:bg-black/5 ${darkMode ? "text-white" : "text-black"}`}
                        >
                          <X size={14} />
                        </button>
                      )}
                      <button
                        onClick={() => {
                          setIsSearchExpanded(false);
                          setSearchQuery("");
                        }}
                        className={`p-1 rounded-full transition-colors ${darkMode ? "hover:bg-white/10" : "hover:bg-black/10"}`}
                      >
                        <X size={18} className="text-[#9CA3AF]" />
                      </button>
                    </div>

                    {/* SEARCH RESULTS OVERLAY */}
                    <AnimatePresence>
                      {searchQuery && (
                        <motion.div
                          initial={{ opacity: 0, y: 10 }}
                          animate={{ opacity: 1, y: 0 }}
                          exit={{ opacity: 0, y: 10 }}
                          className={`absolute top-full left-0 right-0 mt-2 mx-1 rounded-3xl overflow-hidden shadow-2xl z-[100] ${darkMode ? "bg-[#1E2536] border border-white/10" : "bg-white border border-gray-100"}`}
                        >
                          <div className="max-h-[60vh] overflow-y-auto p-4 custom-scrollbar">
                            {/* SECTIONS */}
                            {filteredResults.sections.length > 0 && (
                              <div className="mb-4">
                                <h4 className="text-[10px] uppercase tracking-wider font-bold text-gray-400 mb-2 px-2">App Sections</h4>
                                <div className="space-y-1">
                                  {filteredResults.sections.map(sec => (
                                    <button
                                      key={sec.id}
                                      onClick={() => {
                                        setActiveNavId(sec.tab);
                                        if (sec.clickTarget) setActiveTab(sec.clickTarget);
                                        if (sec.clickAction) sec.clickAction();
                                        setIsSearchExpanded(false);
                                        setSearchQuery("");
                                      }}
                                      className={`w-full flex items-center gap-3 p-2 rounded-xl transition-colors ${darkMode ? "hover:bg-white/5" : "hover:bg-black/5"}`}
                                    >
                                      <div className={`w-8 h-8 rounded-lg flex items-center justify-center ${darkMode ? "bg-white/10 text-white" : "bg-gray-100 text-gray-700"}`}>
                                        {sec.icon}
                                      </div>
                                      <span className={`text-sm font-medium ${darkMode ? "text-gray-200" : "text-gray-700"}`}>{sec.name}</span>
                                    </button>
                                  ))}
                                </div>
                              </div>
                            )}

                            {/* SERVICES & CATEGORIES */}
                            {filteredResults.services.length > 0 && (
                              <div className="mb-4">
                                <h4 className="text-[10px] uppercase tracking-wider font-bold text-gray-400 mb-2 px-2">Services & Categories</h4>
                                <div className="space-y-1">
                                  {filteredResults.services.map((service: any) => (
                                    <button
                                      key={`${service._id}-${service.type}`}
                                      onClick={() => {
                                        if (service.type === 'Main Category') {
                                          handleServiceClick(service);
                                        } else if (service.type === 'Sub Category' || service.type === 'Service') {
                                          // For deep results, we open the parent first, then the item
                                          if (service.parent) {
                                            handleServiceClick(service.parent).then(() => {
                                              // If it's a deep service, we might need more logic here
                                              // For now, opening parent is a good start
                                            });
                                          }
                                        }
                                        setIsSearchExpanded(false);
                                        setSearchQuery("");
                                      }}
                                      className={`w-full flex items-center gap-3 p-2 rounded-xl transition-colors ${darkMode ? "hover:bg-white/5" : "hover:bg-black/5"}`}
                                    >
                                      <div className={`w-10 h-10 rounded-xl flex items-center justify-center ${darkMode ? "bg-white/10 text-white" : "bg-gray-100 text-gray-700"}`}>
                                        {serviceIcons[service.name || service.serviceName] || <Search size={18} />}
                                      </div>
                                      <div className="text-left flex-1 min-w-0">
                                        <p className={`text-sm font-bold truncate ${darkMode ? "text-gray-200" : "text-gray-700"}`}>{service.name || service.serviceName}</p>
                                        <div className="flex items-center gap-1.5">
                                          <span className="text-[10px] text-yellow-500 font-bold uppercase tracking-tight">{service.type}</span>
                                          {service.parent && (
                                            <>
                                              <ChevronRight size={10} className="text-gray-500" />
                                              <span className="text-[10px] text-gray-500 truncate">in {service.parent.name || service.parent.serviceName}</span>
                                            </>
                                          )}
                                        </div>
                                      </div>
                                    </button>
                                  ))}
                                </div>
                              </div>
                            )}

                            {/* BOOKINGS */}
                            {filteredResults.bookings.length > 0 && (
                              <div className="mb-2">
                                <h4 className="text-[10px] uppercase tracking-wider font-bold text-gray-400 mb-2 px-2">Your Bookings</h4>
                                <div className="space-y-1">
                                  {filteredResults.bookings.map(booking => (
                                    <button
                                      key={booking.documentId}
                                      onClick={() => {
                                        setActiveNavId('bookings');
                                        setIsSearchExpanded(false);
                                        setSearchQuery("");
                                      }}
                                      className={`w-full flex items-center gap-3 p-2 rounded-xl transition-colors ${darkMode ? "hover:bg-white/5" : "hover:bg-black/5"}`}
                                    >
                                      <div className={`w-8 h-8 rounded-lg flex items-center justify-center ${darkMode ? "bg-blue-500/20 text-blue-500" : "bg-blue-50 text-blue-600"}`}>
                                        <History size={16} />
                                      </div>
                                      <div className="text-left">
                                        <p className={`text-sm font-medium ${darkMode ? "text-gray-200" : "text-gray-700"}`}>{booking.serviceName}</p>
                                        <p className="text-[10px] text-gray-500">ID: {booking.documentId}</p>
                                      </div>
                                    </button>
                                  ))}
                                </div>
                              </div>
                            )}

                            {filteredResults.services.length === 0 && filteredResults.bookings.length === 0 && filteredResults.sections.length === 0 && (
                              <div className="py-8 text-center">
                                <div className={`w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-3 ${darkMode ? "bg-white/5" : "bg-gray-100"}`}>
                                  <Search size={20} className="text-gray-400" />
                                </div>
                                <p className={`text-sm ${darkMode ? "text-gray-400" : "text-gray-500"}`}>No results found for "{searchQuery}"</p>
                              </div>
                            )}
                          </div>
                        </motion.div>
                      )}
                    </AnimatePresence>
                  </motion.div>
                )}
              </AnimatePresence>
            </div>

            <header className={`sticky top-0 z-50 px-4 py-2 transition-colors duration-300 ${darkMode ? "bg-[#050B14]/80 backdrop-blur-md" : "bg-white/80 backdrop-blur-md"}`}>
              <div className="flex items-center justify-between">
                {/* LEFT: Menu & Location */}
                <div className="flex items-center flex-1 min-w-0">
                  <button onClick={() => setShowDepartmentSheet(true)} className="p-2 -ml-2 rounded-full hover:bg-gray-100 dark:hover:bg-white/10 transition-colors">
                    <Grid3x3 size={24} className={darkMode ? "text-white" : "text-gray-900"} />
                  </button>

                  <LocationHeader
                    label={userData?.name ? `Hi, ${userData.name.split(' ')[0]}` : (location === "Loading..." ? "Locating..." : "Current Location")}
                    address={location === "Loading..." ? "Detecting location..." : location}
                    onClick={() => router.push('/location-settings')} // Or open address sheet if available
                    darkMode={darkMode}
                  />
                </div>

                {/* RIGHT: Actions & Profile */}
                <div className="flex items-center gap-2 ml-2 shrink-0">
                  {/* Search Toggle */}
                  {!isSearchExpanded && (
                    <button
                      onClick={() => {
                        setIsSearchExpanded(true);
                        setSearchQuery("");
                      }}
                      className={`w-10 h-10 rounded-full flex items-center justify-center transition-all ${darkMode ? "bg-[#1E2536] text-gray-400" : "bg-white text-gray-500 shadow-sm"}`}
                    >
                      <Search size={19} />
                    </button>
                  )}

                  {/* Notifications */}
                  <button
                    onClick={() => setShowNotificationSheet(true)}
                    className={`w-10 h-10 rounded-full flex items-center justify-center relative hover:opacity-80 transition-colors ${darkMode ? "bg-[#1E2536]" : "bg-white shadow-sm"}`}
                  >
                    <Bell size={19} className={darkMode ? "text-gray-300" : "text-gray-600"} />
                    <span
                      className={`absolute top-2.5 right-3 w-2 h-2 bg-red-500 rounded-full border ${darkMode ? "border-[#1E2536]" : "border-white"}`}
                    />
                  </button>

                  {/* Theme Toggle */}
                  <button
                    onClick={toggleDarkMode}
                    className={`w-10 h-10 rounded-full flex items-center justify-center hover:opacity-80 transition-colors ${darkMode ? "bg-[#1E2536]" : "bg-white shadow-sm"}`}
                  >
                    {darkMode ? <Sun size={19} className="text-yellow-400" /> : <Moon size={19} className="text-gray-600" />}
                  </button>

                  {/* User Profile Section */}
                  <div className="flex items-center" onClick={() => { if (!userData) openModal('auth'); else setShowEditProfileSheet(true); }}>
                    {/* Lottie Animation (Always Visible as 'Buddy') */}
                    <div className="h-14 w-14 ml-1 flex items-center justify-center shrink-0">
                      <Lottie
                        animationData={userFallbackAnimation}
                        loop={true}
                        className="w-full h-full"
                      />
                    </div>

                    {/* User Profile Image (Visible if available) */}
                    {(userData?.photoUrl || userData?.profileImage || userData?.image) && (
                      <div className="h-10 w-10 ml-2 rounded-full bg-blue-50 flex items-center justify-center shrink-0 border border-blue-100 shadow-sm overflow-hidden">
                        <img src={userData.photoUrl || userData.profileImage || userData.image} alt="User" className="h-full w-full object-cover" />
                      </div>
                    )}
                  </div>
                </div>
              </div>

              {/* Generic Search Bar (Visible when Expanded) */}
              <AnimatePresence>
                {isSearchExpanded && (
                  <motion.div
                    initial={{ opacity: 0, y: -10 }}
                    animate={{ opacity: 1, y: 0 }}
                    exit={{ opacity: 0, y: -10 }}
                    className="absolute top-0 left-0 right-0 z-50 p-2 bg-white dark:bg-[#050B14] shadow-lg"
                  >
                    <div className="flex items-center gap-2">
                      <div className="relative flex-1">
                        <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" size={18} />
                        <input
                          type="text"
                          placeholder="Search for services, repairs..."
                          value={searchQuery}
                          onChange={(e) => setSearchQuery(e.target.value)}
                          autoFocus
                          className={`w-full pl-10 pr-4 py-3 rounded-xl outline-none transition-all ${darkMode ? "bg-[#1E2536] text-white placeholder-gray-500" : "bg-gray-100 text-gray-900 placeholder-gray-400"}`}
                        />
                        {searchQuery && (
                          <button onClick={() => setSearchQuery("")} className="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">
                            <X size={16} />
                          </button>
                        )}
                      </div>
                      <button onClick={() => setIsSearchExpanded(false)} className={`p-3 rounded-xl font-medium ${darkMode ? "text-gray-300 hover:bg-white/5" : "text-gray-600 hover:bg-gray-100"}`}>
                        Cancel
                      </button>
                    </div>
                    {searchQuery.trim() && (
                      <div className={`mt-2 rounded-xl shadow-xl max-h-[60vh] overflow-y-auto ${darkMode ? "bg-[#1E2536]" : "bg-white"}`}>
                        {/* SERVICES */}
                        {filteredResults.services.length > 0 && (
                          <div className="mb-4">
                            <h4 className="text-[10px] uppercase tracking-wider font-bold text-gray-400 mb-2 px-2">Services</h4>
                            <div className="space-y-1">
                              {filteredResults.services.map(service => (
                                <button
                                  key={service._id || service.documentId}
                                  onClick={() => {
                                    if (service.type === 'Main Category') {
                                      handleServiceClick(service);
                                    } else if (service.type === 'Sub Category' || service.type === 'Service') {
                                      // For deep results, we open the parent first, then the item
                                      if (service.parent) {
                                        handleServiceClick(service.parent).then(() => {
                                          // If it's a deep service, we might need more logic here
                                          // For now, opening parent is a good start
                                        });
                                      }
                                    }
                                    setIsSearchExpanded(false);
                                    setSearchQuery("");
                                  }}
                                  className={`w-full flex items-center gap-3 p-2 rounded-xl transition-colors ${darkMode ? "hover:bg-white/5" : "hover:bg-black/5"}`}
                                >
                                  <div className={`w-10 h-10 rounded-xl flex items-center justify-center ${darkMode ? "bg-white/10 text-white" : "bg-gray-100 text-gray-700"}`}>
                                    {serviceIcons[service.name || service.serviceName] || <Search size={18} />}
                                  </div>
                                  <div className="text-left flex-1 min-w-0">
                                    <p className={`text-sm font-bold truncate ${darkMode ? "text-gray-200" : "text-gray-700"}`}>{service.name || service.serviceName}</p>
                                    <div className="flex items-center gap-1.5">
                                      <span className="text-[10px] text-yellow-500 font-bold uppercase tracking-tight">{service.type}</span>
                                      {service.parent && (
                                        <>
                                          <ChevronRight size={10} className="text-gray-500" />
                                          <span className="text-[10px] text-gray-500 truncate">in {service.parent.name || service.parent.serviceName}</span>
                                        </>
                                      )}
                                    </div>
                                  </div>
                                </button>
                              ))}
                            </div>
                          </div>
                        )}

                        {/* BOOKINGS */}
                        {filteredResults.bookings.length > 0 && (
                          <div className="mb-2">
                            <h4 className="text-[10px] uppercase tracking-wider font-bold text-gray-400 mb-2 px-2">Your Bookings</h4>
                            <div className="space-y-1">
                              {filteredResults.bookings.map(booking => (
                                <button
                                  key={booking.documentId}
                                  onClick={() => {
                                    setActiveNavId('bookings');
                                    setIsSearchExpanded(false);
                                    setSearchQuery("");
                                  }}
                                  className={`w-full flex items-center gap-3 p-2 rounded-xl transition-colors ${darkMode ? "hover:bg-white/5" : "hover:bg-black/5"}`}
                                >
                                  <div className={`w-8 h-8 rounded-lg flex items-center justify-center ${darkMode ? "bg-blue-500/20 text-blue-500" : "bg-blue-50 text-blue-600"}`}>
                                    <History size={16} />
                                  </div>
                                  <div className="text-left">
                                    <p className={`text-sm font-medium ${darkMode ? "text-gray-200" : "text-gray-700"}`}>{booking.serviceName}</p>
                                    <p className="text-[10px] text-gray-500">ID: {booking.documentId}</p>
                                  </div>
                                </button>
                              ))}
                            </div>
                          </div>
                        )}

                        {filteredResults.services.length === 0 && filteredResults.bookings.length === 0 && filteredResults.sections.length === 0 && (
                          <div className="py-8 text-center">
                            <div className={`w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-3 ${darkMode ? "bg-white/5" : "bg-gray-100"}`}>
                              <Search size={20} className="text-gray-400" />
                            </div>
                            <p className={`text-sm ${darkMode ? "text-gray-400" : "text-gray-500"}`}>No results found for "{searchQuery}"</p>
                          </div>
                        )}
                      </div>
                    )}
                  </motion.div>
                )}
              </AnimatePresence>

              <button
                onClick={() => setShowRiderDashboard(true)}
                className="w-full bg-[#FFC42E] hover:bg-[#EAB308] active:scale-95 transition-all text-[#111827] font-semibold py-2.5 rounded-2xl flex items-center justify-center gap-2 shadow-[0_4px_15px_rgba(255,196,46,0.2)] mt-2"
              >
                <Bike size={20} />
                RIDER MODE
              </button>
            </header>
      )}

            {activeNavId === 'home' ? (
              <main className="px-5 mt-2 space-y-6">
                {/* TABS - Centered and Non-scrollable */}
                <div className="grid grid-cols-3 gap-2 px-1 pb-1">
                  {tabs.map((tab) => (
                    <button
                      key={tab}
                      onClick={() => {
                        if (tab === 'Resell') {
                          router.push('/test-notification');
                        } else {
                          setActiveTab(tab);
                        }
                      }}
                      className={`py-2.5 rounded-full font-semibold text-sm whitespace-nowrap transition-all text-center ${activeTab === tab ? "bg-[#FFC42E] text-[#111827] shadow-md shadow-yellow-500/20" : `border ${darkMode ? "bg-[#1E2536] text-gray-300 border-gray-800" : "bg-white text-gray-600 border-gray-100"}`}`}
                    >
                      {tab}
                    </button>
                  ))}
                </div>

                {/* ADVANCED STORY BANNER */}
                <div className="relative h-[220px] w-full overflow-hidden rounded-[2.5rem] shadow-2xl bg-black group">
                  {/* Background Content */}
                  <AnimatePresence mode="wait">
                    <motion.div
                      key={currentIndex}
                      initial={{ opacity: 0, scale: 1.1 }}
                      animate={{ opacity: 1, scale: 1 }}
                      exit={{ opacity: 0 }}
                      transition={{ duration: 0.6 }}
                      className="absolute inset-0"
                    >
                      {banners[currentIndex].type === 'video' ? (
                        <video
                          ref={videoRef}
                          src={banners[currentIndex].url}
                          autoPlay
                          muted
                          playsInline
                          onTimeUpdate={handleVideoTimeUpdate}
                          onEnded={handleVideoEnd}
                          className="w-full h-full object-cover brightness-50"
                        />
                      ) : (
                        <img
                          src={banners[currentIndex].url}
                          alt={banners[currentIndex].title}
                          className="w-full h-full object-cover brightness-50"
                        />
                      )}

                      {/* Overlay Text */}
                      <div className="absolute inset-0 p-8 flex flex-col justify-end bg-gradient-to-t from-black/80 via-black/20 to-transparent">
                        <motion.div
                          initial={{ y: 20, opacity: 0 }}
                          animate={{ y: 0, opacity: 1 }}
                          transition={{ delay: 0.3 }}
                        >
                          <h2 className="text-3xl font-black text-white mb-2 leading-tight">
                            {banners[currentIndex].title}
                          </h2>
                          <p className="text-gray-200 text-sm font-medium mb-4 max-w-[80%]">
                            {banners[currentIndex].subtitle}
                          </p>
                          <button className="bg-[#FFC42E] text-[#111827] px-8 py-2.5 rounded-2xl font-black text-sm uppercase tracking-wider hover:scale-105 active:scale-95 transition-all">
                            Check Now
                          </button>
                        </motion.div>
                      </div>
                    </motion.div>
                  </AnimatePresence>

                  {/* SEGMENTED PROGRESS BARS (Story Style) */}
                  <div className="absolute top-4 left-6 right-6 flex gap-2 z-20">
                    {banners.map((banner, index) => (
                      <div key={banner.id} className="h-1 flex-1 bg-white/20 rounded-full overflow-hidden">
                        <div
                          className="h-full bg-[#FFC42E] transition-all duration-100 ease-linear"
                          style={{
                            width: index === currentIndex ? `${progress}%` : index < currentIndex ? '100%' : '0%'
                          }}
                        />
                      </div>
                    ))}
                  </div>

                  {/* Navigation Areas */}
                  <div className="absolute inset-y-0 left-0 w-1/4 z-30 cursor-pointer" onClick={() => {
                    setCurrentIndex((prev) => (prev - 1 + banners.length) % banners.length);
                    setProgress(0);
                  }} />
                  <div className="absolute inset-y-0 right-0 w-1/4 z-30 cursor-pointer" onClick={() => {
                    setCurrentIndex((prev) => (prev + 1) % banners.length);
                    setProgress(0);
                  }} />
                </div>



                {/* DEPARTMENTS - Advanced Conditional Rendering */}
                {departments.filter(d => !d.isAll).length >= 2 && (
                  <section
                    ref={departmentSectionRef}
                    className="z-40 mb-6"
                  >
                    <div className="mb-4 px-1">
                      <h3 className={`text-lg font-bold ${darkMode ? "text-white" : "text-[#111827]"}`}>Department</h3>
                    </div>
                    <div className={`flex gap-4 pb-2 items-center ${departments.filter(d => !d.isAll).length === 2 ? "justify-center" : "flex-wrap justify-start"}`}>
                      {departments.map((dept, index) => (
                        <button
                          key={index}
                          onClick={() => handleDepartmentClick(dept.id)}
                          className="group flex flex-col items-center gap-2 min-w-[70px] transition-all"
                        >
                          <div
                            className={`rounded-full flex items-center justify-center shadow-md overflow-hidden w-16 h-16 transition-all duration-300 ${dept.isAll
                              ? "bg-[#1F2937] text-white"
                              : (darkMode ? dept.darkBgColor : dept.bgColor)
                              }`}
                          >
                            {dept.image ? (
                              <img
                                alt={dept.name}
                                className="w-full h-full object-cover"
                                src={dept.image}
                              />
                            ) : (
                              <div className="">
                                {dept.icon}
                              </div>
                            )}
                          </div>
                          <span
                            className={`font-medium text-center leading-tight text-xs ${darkMode ? "text-[#9CA3AF]" : "text-[#6B7280]"
                              }`}
                          >
                            {dept.name.replace("\n", " ")}
                          </span>
                        </button>
                      ))}
                    </div>
                  </section>
                )}
                {/* Spacer removed - no longer needed with new sticky design */}

                {/* SERVICES GRID */}
                <section>
                  <div className="flex justify-between items-end mb-4">
                    <h3 className={`text-lg font-bold ${darkMode ? "text-white" : "text-[#111827]"}`}>
                      {selectedDepartment === "all" ? "Select Service" : selectedDepartment}
                    </h3>
                  </div>
                  <div className="grid grid-cols-4 gap-4">
                    {loadingServices ? (
                      // Loading Skeletons
                      Array.from({ length: 8 }).map((_, i) => (
                        <div key={i} className="flex flex-col items-center gap-2">
                          <div className={`w-16 h-16 rounded-2xl animate-pulse ${darkMode ? "bg-gray-800" : "bg-gray-200"}`} />
                          <div className={`w-12 h-3 rounded animate-pulse ${darkMode ? "bg-gray-800" : "bg-gray-200"}`} />
                        </div>
                      ))
                    ) : (
                      getFilteredServices().map((service, index) => {
                        const style = getServiceStyle(service);
                        const serviceName = service.name || service.serviceName;
                        const isAcService = /\bac\b|air\s?conditioner/i.test(serviceName || "");
                        const isImageVisible = service.isMainCategoryImageVisible !== false;
                        return (
                          <button
                            key={service._id || index}
                            onClick={(e) => handleServiceClick(service, e)}
                            className="group relative flex flex-col items-center active:scale-95 transition-transform duration-100 card-pop"
                          >
                            <div
                              className={`relative w-20 h-20 rounded-2xl flex items-center justify-center transition-all duration-300 group-hover:-translate-y-1.5 group-hover:shadow-[0_12px_30px_-10px_rgba(255,196,46,0.3)] overflow-hidden ${darkMode
                                ? "bg-[#151C2C] border border-white/10 shadow-[0_8px_20px_rgba(0,0,0,0.4)]"
                                : "bg-white shadow-[6px_6px_12px_#d1d9e6,-6px_-6px_12px_#ffffff]"
                                }`}
                            >
                              <div className={`w-14 h-14 flex items-center justify-center p-1 transition-transform duration-300 group-hover:scale-110`}
                              >
                                {isImageVisible && service.imageUri ? (
                                  <img
                                    src={service.imageUri}
                                    alt={serviceName}
                                    className="w-full h-full object-contain filter drop-shadow-[0_5px_10px_rgba(0,0,0,0.15)]"
                                  />
                                ) : (
                                  <div className={`w-full h-full rounded-xl ${style.bgColor} dark:${style.darkBgColor} flex items-center justify-center shadow-inner`}>
                                    {serviceIcons[serviceName] || <Wrench size={22} className={style.iconColor} />}
                                  </div>
                                )}
                              </div>
                            </div>
                            <span className={`mt-3 text-[11px] font-semibold text-center tracking-wide leading-tight line-clamp-2 ${darkMode ? "text-[#D1D5DB]" : "text-[#4B5563]"}`}
                            >
                              {serviceName}
                            </span>
                          </button>
                        );
                      })
                    )}
                  </div>
                </section>
              </main>
            ) : (
              <div className={`flex flex-col min-h-[70vh] ${darkMode ? "text-white" : "text-gray-900"}`}>
                {activeNavId === 'profile' ? (
                  <ProfileView
                    userData={userData}
                    darkMode={darkMode}
                    onLoginClick={() => openModal('auth')}
                  />
                ) : (
                  <motion.div
                    key={activeNavId}
                    initial={{ opacity: 0, y: 10 }}
                    animate={{ opacity: 1, y: 0 }}
                    className={`flex-1 flex flex-col ${activeNavId === 'history' ? 'bg-[#F3F4F8]' : 'px-6 items-center justify-center gap-4'}`}
                    style={{ paddingBottom: '90px' }}
                  >
                    {activeNavId === 'history' ? (
                      <div className="w-full h-full flex flex-col">
                        {/* My Bookings Header */}
                        <div className="bg-white p-6 pb-4 shadow-sm border-b border-gray-100">
                          <h2 className="text-2xl font-bold text-gray-900">My Bookings</h2>
                          <p className="text-gray-500 text-sm mt-1">Track your active and past services</p>
                        </div>

                        <div className="flex-1 overflow-y-auto p-4 space-y-4">
                          {/* Check if logged in first */}
                          {!userData && !localStorage.getItem('userId') ? (
                            <div className="flex flex-col items-center justify-center py-20 text-center">
                              <div className="w-20 h-20 bg-blue-50 rounded-full flex items-center justify-center mb-4">
                                <User className="w-10 h-10 text-blue-500" />
                              </div>
                              <h3 className="text-lg font-bold text-gray-900">Login to see bookings</h3>
                              <p className="text-gray-500 text-sm mt-2 px-10">Sign in to track your service history and active bookings in real-time.</p>
                              <button
                                onClick={() => openModal('auth')}
                                className="mt-6 px-8 py-3 bg-[#FFC42E] rounded-2xl font-bold text-[#111827] shadow-lg shadow-yellow-500/20 active:scale-95 transition-all"
                              >
                                Login Now
                              </button>
                            </div>
                          ) : loadingBookings ? (
                            <div className="flex flex-col items-center justify-center py-12">
                              <Loader2 className="w-8 h-8 text-yellow-500 animate-spin mb-2" />
                              <p className="text-gray-500 text-sm">Loading your bookings...</p>
                            </div>
                          ) : userBookings.length === 0 ? (
                            <div className="flex flex-col items-center justify-center py-20 text-center">
                              <div className="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mb-4">
                                <ClipboardList className="w-10 h-10 text-gray-300" />
                              </div>
                              <h3 className="text-lg font-bold text-gray-900">No bookings yet</h3>
                              <p className="text-gray-500 text-sm mt-2 px-10">You haven't made any bookings yet. Start by exploring our services.</p>
                              <div className="flex flex-col gap-3 mt-6">
                                <button
                                  onClick={() => setActiveNavId('home')}
                                  className="px-8 py-3 bg-[#FFC42E] rounded-2xl font-bold text-[#111827] shadow-lg shadow-yellow-500/20 active:scale-95 transition-all"
                                >
                                  Book a Service
                                </button>
                                <button
                                  onClick={() => {
                                    // Force a re-fetch by triggering effect or calling a function
                                    const dummy = { ...userData };
                                    setUserData(dummy);
                                    console.log("🔄 Manual Refresh Clicked");
                                  }}
                                  className="text-yellow-600 font-bold text-sm hover:underline"
                                >
                                  Refresh My Bookings
                                </button>
                              </div>
                            </div>
                          ) : (
                            userBookings.map((booking, idx) => {
                              const isAssigned = booking.status?.toLowerCase().includes('assigned') || !!booking.technician;
                              return (
                                <div
                                  key={booking.serviceId || idx}
                                  onClick={() => router.push(`/bookings/${booking.serviceId}`)}
                                  className="bg-white rounded-[2rem] p-5 shadow-sm border border-gray-100 relative overflow-hidden transition-all active:scale-[0.98] hover:shadow-md cursor-pointer"
                                >
                                  {/* Status Badge */}
                                  <div className="flex justify-between items-start mb-4">
                                    <div className="flex items-center gap-2">
                                      <div className={`px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider ${isAssigned ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700'
                                        }`}>
                                        {isAssigned ? 'Technician Assigned' : 'Finding Technician...'}
                                      </div>
                                    </div>
                                    <span className="text-[10px] font-bold text-gray-400">ID: {booking.serviceId?.substring(0, 10)}...</span>
                                  </div>

                                  <div className="flex items-center gap-4">
                                    <div className="w-16 h-16 rounded-2xl bg-gray-50 flex items-center justify-center border border-gray-100">
                                      <span className="text-3xl">⚡</span>
                                    </div>
                                    <div className="flex-1">
                                      <h3 className="font-bold text-gray-900 text-lg leading-tight">
                                        {booking.serviceName ||
                                          booking.metaModels?.serviceName ||
                                          (booking.serviceDetails && Object.values(booking.serviceDetails)[0] && (Object.values(booking.serviceDetails)[0] as any).serviceName) ||
                                          "Service Booking"}
                                      </h3>
                                      <div className="flex items-center gap-3 mt-1 text-xs text-gray-500">
                                        <div className="flex items-center gap-1">
                                          <Clock size={12} />
                                          <span>{booking.metaModels?.bookDate} {booking.metaModels?.bookTime}</span>
                                        </div>
                                      </div>
                                    </div>
                                  </div>

                                  {/* Technician Section */}
                                  <div className={`mt-4 pt-4 border-t border-dashed border-gray-100 ${isAssigned ? 'opacity-100' : 'opacity-80'}`}>
                                    {isAssigned ? (
                                      <div className="flex items-center justify-between">
                                        <div className="flex items-center gap-3">
                                          <div className="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center">
                                            <User size={20} className="text-blue-600" />
                                          </div>
                                          <div>
                                            <p className="text-xs font-bold text-gray-900">{booking.technician?.name || "Professional Assigned"}</p>
                                            <p className="text-[10px] text-gray-500">Arriving in approx 20 mins</p>
                                          </div>
                                        </div>
                                        <button className="w-9 h-9 bg-green-500 text-white rounded-full flex items-center justify-center shadow-lg shadow-green-500/20 active:scale-90 transition-all">
                                          <Phone size={18} />
                                        </button>
                                      </div>
                                    ) : (
                                      <div className="flex items-center gap-3 py-1">
                                        <div className="flex gap-1">
                                          <div className="w-1.5 h-1.5 bg-yellow-400 rounded-full animate-bounce" />
                                          <div className="w-1.5 h-1.5 bg-yellow-400 rounded-full animate-bounce [animation-delay:0.2s]" />
                                          <div className="w-1.5 h-1.5 bg-yellow-400 rounded-full animate-bounce [animation-delay:0.4s]" />
                                        </div>
                                        <p className="text-xs text-gray-500 italic">Finding the best professional for you...</p>
                                      </div>
                                    )}
                                  </div>
                                </div>
                              );
                            })
                          )}
                        </div>
                      </div>
                    ) : (
                      <>
                        <div className="text-4xl">
                          {activeNavId === 'rewards' && "🎁"}
                        </div>
                        <h2 className="text-2xl font-bold capitalize">
                          {activeNavId === 'rewards' ? "Rewards" : activeNavId}
                        </h2>
                        <p className="text-gray-500 text-center">
                          This is the {activeNavId} section of the app.
                        </p>
                        <button
                          onClick={() => setActiveNavId('home')}
                          className="mt-6 px-8 py-3 bg-[#FFC42E] rounded-2xl font-bold text-[#111827] shadow-lg shadow-yellow-500/20 active:scale-95 transition-all"
                        >
                          Back to Home
                        </button>
                      </>
                    )}
                  </motion.div>

                )}
              </div>
            )}

            {/* BOTTOM NAVIGATION */}
            <div className={`fixed bottom-0 left-0 right-0 z-[60] transition-transform duration-[600ms] ease-[cubic-bezier(0.4, 0, 0.2, 1)] pointer-events-none ${(showBottomNav && !showDepartmentSheet && !showCategoryPopup && !showChildCategoryPopup) ? 'translate-y-0' : 'translate-y-[120%]'}`}>
              <nav
                className={`relative flex justify-between items-center w-full h-[66px] transition-all duration-500 rounded-t-[2.5rem] shadow-[0_-15px_50px_rgba(0,0,0,0.15)] border-x-4 ${darkMode ? 'border-[#111827]' : 'border-white'} pointer-events-auto ${darkMode
                  ? "bg-[#111827]/95 backdrop-blur-2xl border-t border-white/5"
                  : "bg-white/95 backdrop-blur-2xl border-t border-gray-100"
                  }`}
              >
                {/* Mapping items */}
                {[
                  { label: "Home", icon: Home, id: "home" },
                  { label: "My Bookings", icon: ClipboardList, id: "history" },
                  { label: "Hire", icon: Wrench, id: "hire", isSpecial: true },
                  { label: "Rewards", icon: Gift, id: "rewards" },
                  { label: "Profile", icon: User, id: "profile" }
                ].map((item, idx) => {
                  const Icon: any = item.icon;
                  const isActive = activeNavId === item.id;

                  if (item.isSpecial) {
                    return (
                      <div key={item.id} className="flex-1 flex justify-center items-center relative h-full">
                        <div className="absolute top-[-30px] flex flex-col items-center group">
                          <button
                            onClick={() => setActiveNavId('home')}
                            className={`w-[62px] h-[62px] rounded-full flex items-center justify-center transition-all duration-500 bg-[#FFC42E] shadow-[0_0_30px_rgba(255,196,46,0.6),0_10px_20px_rgba(0,0,0,0.2)] hover:scale-110 active:scale-90 border-4 ${darkMode ? 'border-[#111827]' : 'border-white'}`}
                          >
                            <Icon className="text-gray-900" size={28} />
                          </button>
                          <div className="absolute inset-0 rounded-full bg-[#FFC42E]/30 blur-xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" />
                        </div>
                      </div>
                    );
                  }

                  return (
                    <div key={item.id} className="flex-1 flex justify-center items-center h-full">
                      <button
                        onClick={() => setActiveNavId(item.id)}
                        className="group relative flex flex-col items-center justify-center gap-1 w-full h-full outline-none pt-2"
                      >
                        <div className={`relative transition-all duration-300 ${isActive
                          ? "text-[#FFC42E] -translate-y-0.5"
                          : darkMode ? "text-gray-500 group-hover:text-gray-300" : "text-gray-400 group-hover:text-gray-700"
                          }`}>
                          <Icon size={isActive ? 22 : 20} className={isActive ? "stroke-[2.5px]" : "stroke-[2px]"} />
                        </div>
                        <span className={`text-[10px] font-bold transition-colors duration-300 ${isActive
                          ? "text-[#FFC42E]"
                          : darkMode ? "text-gray-500" : "text-gray-400"
                          }`}>
                          {item.label}
                        </span>
                      </button>
                    </div>
                  );
                })}
              </nav>
            </div>

            <AnimatePresence>
              {/* Basic toast removed in favor of premium modal */}
            </AnimatePresence>

            <DepartmentSheet
              isOpen={showDepartmentSheet}
              onClose={() => setShowDepartmentSheet(false)}
              selectedDepartment={sheetDepartment}
              services={sheetDepartment === "all" ? servicesFromApi : servicesFromApi.filter((s) => s.parentId === sheetDepartment)}
              onServiceClick={handleServiceClick}
              darkMode={darkMode}
            />
            <AnimatePresence>
              {showCategoryPopup && activeService && (
                <ServiceCategoryPopup
                  activeService={activeService}
                  subCategories={subCategories}
                  popupHistory={popupHistory}
                  clickPosition={clickPosition}
                  darkMode={darkMode}
                  onClose={() => {
                    setShowCategoryPopup(false);
                    setSubCategories([]);
                    setActiveService(null);
                    setActiveSubCategory(null);
                    setCurrentLevel("main");
                    setPopupHistory([]);
                  }}
                  onBack={handlePopupBack}
                  onSubClick={handleSubCategoryClick}
                  checkSubChildVisibility={checkSubChildVisibility}
                />
              )}
            </AnimatePresence>

            {/* Login Popup */}
            <AuthModal darkMode={darkMode} />

            <ServiceUnavailableModal
              isOpen={showPremiumUnavailable}
              onClose={() => setShowPremiumUnavailable(false)}
              serviceName={unavailableServiceName}
              darkMode={darkMode}
            />

            <NotificationSheet
              isOpen={showNotificationSheet}
              onClose={() => setShowNotificationSheet(false)}
              notifications={notifications}
              darkMode={darkMode}
            />

            <EditProfileSheet
              isOpen={showEditProfileSheet}
              onClose={() => setShowEditProfileSheet(false)}
              userData={userData}
              darkMode={darkMode}
              onUpdateSuccess={(updatedData) => {
                setUserData(updatedData);
                localStorage.setItem('userData', JSON.stringify(updatedData));
              }}
            />

            <RiderModeDashboard
              isOpen={showRiderDashboard}
              onClose={() => setShowRiderDashboard(false)}
              darkMode={darkMode}
            />
          </div>
          );
}

          // ---------- Sub-components ----------

          const ServiceCategoryPopup = ({
            activeService,
            subCategories,
            popupHistory,
            clickPosition,
            darkMode,
            onClose,
            onBack,
            onSubClick,
            checkSubChildVisibility
          }: any) => {
  const getPopupTitle = () => {
    if (popupHistory.length > 0) {
      const last = popupHistory[popupHistory.length - 1];
          return last.name || last.title || last.firstTitle || activeService.name;
    }
          return activeService.name || activeService.serviceName;
  };

  const getLevelLabel = () => {
    return "Choose Sub Category";
  };

          return (
          <div className="fixed inset-0 z-[100] flex items-center justify-center p-4">
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              className="absolute inset-0 bg-black/60 backdrop-blur-sm"
              onClick={onClose}
            />
            <motion.div
              key="popup-content"
              initial={{
                opacity: 0,
                scale: 0.1,
                x: clickPosition.x - (typeof window !== 'undefined' ? window.innerWidth / 2 : 0),
                y: clickPosition.y - (typeof window !== 'undefined' ? window.innerHeight / 2 : 0),
                rotateX: 45,
                clipPath: "polygon(48% 100%, 52% 100%, 100% 100%, 100% 100%, 0% 100%, 0% 100%)",
              }}
              animate={{
                opacity: 1,
                scale: 1,
                x: 0,
                y: 0,
                rotateX: 0,
                clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 80% 100%, 20% 100%, 0% 100%)",
              }}
              exit={{
                opacity: 0,
                scale: 0.1,
                x: clickPosition.x - (typeof window !== 'undefined' ? window.innerWidth / 2 : 0),
                y: clickPosition.y - (typeof window !== 'undefined' ? window.innerHeight / 2 : 0),
                rotateX: 45,
                clipPath: "polygon(48% 100%, 52% 100%, 100% 100%, 100% 100%, 0% 100%, 0% 100%)",
              }}
              transition={{
                duration: 0.7,
                ease: [0.25, 1, 0.5, 1],
              }}
              className={`relative w-full max-w-[340px] rounded-[2.5rem] p-6 max-h-[80vh] overflow-y-auto border-t border-l shadow-[0_40px_80px_-20px_rgba(0,0,0,0.8)] z-10 ${darkMode
                ? "bg-[#0A0F1C]/85 backdrop-blur-[60px] border-white/10 shadow-[0_0_1px_rgba(255,255,255,0.1)_inset]"
                : "bg-[#0A0F1C]/75 backdrop-blur-[60px] border-white/15 shadow-[0_0_1px_rgba(255,255,255,0.2)_inset]"
                }`}
              style={{
                transformOrigin: "bottom center",
                perspective: "1200px",
                transformStyle: "preserve-3d"
              }}
            >
              <div className="flex items-start justify-between mb-4 sticky top-0 border-b border-white/10 pb-3 z-20">
                <div className="flex items-center gap-3">
                  {popupHistory.length > 1 && (
                    <button
                      onClick={onBack}
                      className="w-8 h-8 flex items-center justify-center rounded-full bg-white/20 hover:bg-white/30 transition-colors"
                    >
                      <ChevronLeft size={18} className="text-white" />
                    </button>
                  )}
                  <div>
                    <span className="text-[10px] font-bold text-[#FFC42E] uppercase tracking-wider block mb-0.5">
                      Explore Categories
                    </span>
                    <h2 className="text-lg font-bold text-white leading-tight">
                      {getPopupTitle()}
                    </h2>
                  </div>
                </div>
                <button
                  onClick={onClose}
                  className="w-8 h-8 flex items-center justify-center rounded-full bg-white/20 hover:bg-white/30 transition-colors"
                >
                  <X size={18} className="text-white" />
                </button>
              </div>
              {subCategories.length === 0 ? (
                <div className="text-center py-10">
                  <p className="text-gray-300 font-medium">No items found</p>
                </div>
              ) : (
                <div className="grid grid-cols-3 gap-3">
                  {subCategories.map((cat: any, idx: number) => {
                    const categoryName = cat.name || cat.title || `Option ${idx + 1}`;
                    if (!checkSubChildVisibility(cat)) return null;

                    // Determine if we should show the image with proper visibility checks
                    const shouldShowImage = (() => {
                      // Helper: Check if visibility value is truly false
                      const isFalsy = (val: any) => {
                        return val === false || val === 'false' || val === '0' || val === 0;
                      };

                      // Check if this is a subcategory with specific image visibility flag
                      if (cat.isSubCategoryImageVisible !== undefined) {
                        if (isFalsy(cat.isSubCategoryImageVisible)) {
                          console.log(`🚫 Sub-category "${categoryName}" image hidden (isSubCategoryImageVisible=${cat.isSubCategoryImageVisible})`);
                          return false;
                        }
                        return !!cat.imageUri;
                      }

                      // Check if this is a deep category with photoVisible flag
                      if (cat.photoVisible !== undefined) {
                        if (isFalsy(cat.photoVisible)) {
                          console.log(`🚫 Category "${categoryName}" photo hidden (photoVisible=${cat.photoVisible})`);
                          return false;
                        }
                        return !!(cat.imageUri || cat.image?.url);
                      }

                      // Check general visibility
                      if (cat.imageVisibility !== undefined) {
                        if (isFalsy(cat.imageVisibility)) {
                          console.log(`🚫 Category "${categoryName}" image hidden (imageVisibility=${cat.imageVisibility})`);
                          return false;
                        }
                      }

                      // Default: show image if it exists and no false visibility flag
                      const hasImage = !!(cat.imageUri || cat.image?.url);
                      if (hasImage) {
                        console.log(`✅ Sub-category "${categoryName}" showing image`);
                      }
                      return hasImage;
                    })();

                    const imageUrl = cat.imageUri || cat.image?.url;

                    return (
                      <button
                        key={cat._id || idx}
                        onClick={() => {
                          onSubClick(cat);
                        }}
                        className="group flex flex-col items-center gap-2 p-3 rounded-2xl bg-white/5 hover:bg-white/10 border border-white/10 transition-all active:scale-95"
                      >
                        <div className="w-14 h-14 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center overflow-hidden shadow-inner group-hover:border-[#FFC42E]/30 transition-colors">
                          {shouldShowImage && imageUrl ? (
                            <img
                              src={imageUrl}
                              alt={categoryName}
                              className="w-full h-full object-cover"
                              onError={(e) => {
                                console.log(`❌ Image failed to load: ${imageUrl}`);
                                const parent = e.currentTarget.parentElement;
                                if (parent) {
                                  parent.innerHTML = '<div class="w-full h-full flex items-center justify-center bg-yellow-400/10"><span class="text-2xl drop-shadow-[0_0_8px_rgba(255,196,46,0.5)]">⚡</span></div>';
                                }
                              }}
                            />
                          ) : (
                            <div className="w-full h-full flex items-center justify-center bg-yellow-400/10">
                              <span className="text-2xl drop-shadow-[0_0_8px_rgba(255,196,46,0.5)]">⚡</span>
                            </div>
                          )}
                        </div>
                        <span className="text-[11px] font-bold text-center text-gray-200 leading-tight line-clamp-2 group-hover:text-[#FFC42E] transition-colors">
                          {categoryName}
                        </span>
                      </button>
                    );
                  })}
                </div>
              )}
            </motion.div>
          </div>
          );
};
